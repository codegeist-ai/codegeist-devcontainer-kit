# .local.env - local runtime env for the devcontainer
#
# Why this exists:
# - Holds machine-local environment variables that should be injected into the
#   devcontainer without changing the checked-in compose defaults.
# - The repository root keeps the manual copy of `.devcontainer/.local.env`.
# - Managed worktrees under `.worktrees/` link to that root-local file.
# - This file remains manual on purpose; `start.sh` does not generate its
#   content.
#
# Related files:
# - .devcontainer/docker-compose.yml
# - .devcontainer/.env
# - .gitignore
GIT_AUTHOR_NAME=your-name
GIT_AUTHOR_EMAIL=you@example.com
GIT_COMMITTER_NAME=${GIT_AUTHOR_NAME}
GIT_COMMITTER_EMAIL=${GIT_AUTHOR_EMAIL}
