# compose.local.yml - repository-visible compose overrides for the devcontainer
#
# Why this exists:
# - Provides a checked-in template for root compose customizations.
# - Copy it to `.codegeist/compose.local.yml` only when a consuming repository
#   needs Compose overrides.
# - `.codegeist/compose.local.yml` is intentionally visible to Git so
#   repositories can decide whether to commit their overrides.
# - Shared defaults live in docker-compose.yml; keep this template empty until a
#   real repository override is needed.
#
# Related files:
# - devcontainer.json
# - docker-compose.yml
# - initialize.sh
# - .codegeist/compose.local.yml
# - compose.user.gen.yml
services: {}
