# compose.local.yml - local compose overrides for the devcontainer
#
# Why this exists:
# - Provides a checked-in template for machine-local compose customizations.
# - `initialize.sh` copies it to `compose.local.yml` when the local override is
#   missing so `devcontainer.json` can always include the override file.
# - The generated `compose.local.yml` is intentionally ignored and may be edited
#   by each consuming checkout or worktree.
#
# Related files:
# - devcontainer.json
# - docker-compose.yml
# - initialize.sh
services:
  workspace:
    environment:
      OPENCODE_EXPERIMENTAL_DISABLE_FILEWATCHER: ${OPENCODE_EXPERIMENTAL_DISABLE_FILEWATCHER:-true}
